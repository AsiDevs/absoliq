{
  "format": "page",
  "id": "blog",
  "label": "Blog",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "blog_category",
              "fields": ["category"]
            }
          ]
        }
      },
      "author": {
        "type": "Link",
        "config": {
          "label": "Author",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "author",
              "fields": ["name", "image"]
            }
          ]
        }
      },
      "post_date": {
        "type": "Date",
        "config": {
          "label": "Post date",
          "placeholder": ""
        }
      },
      "read_time": {
        "type": "Number",
        "config": {
          "label": "Read time",
          "placeholder": ""
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Image",
          "constraint": {
            "width": 1600
          },
          "thumbnails": [
            {
              "name": "thumbnail",
              "width": 400,
              "height": null
            },
            {
              "name": "thumbnail2x",
              "width": 800,
              "height": null
            }
          ]
        }
      },
      "body": {
        "type": "Group",
        "config": {
          "label": "Body",
          "repeat": true,
          "fields": {
            "heading": {
              "type": "StructuredText",
              "config": {
                "label": "Heading",
                "placeholder": "",
                "allowTargetBlank": false,
                "multi": "heading2"
              }
            },
            "content": {
              "type": "StructuredText",
              "config": {
                "label": "Content",
                "placeholder": "",
                "allowTargetBlank": true,
                "multi": "paragraph,hyperlink,image,list-item,o-list-item,heading3,strong,em"
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "cta": {
              "type": "SharedSlice"
            },
            "blogs": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
