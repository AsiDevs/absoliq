{
  "id": "settings",
  "label": "Settings",
  "format": "custom",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "siteTitle": {
        "type": "StructuredText",
        "config": {
          "label": "Site Title",
          "placeholder": "Title of the site",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "header_logo": {
        "type": "Image",
        "config": {
          "label": "Header Logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "footer_logo": {
        "type": "Image",
        "config": {
          "label": "Footer Logo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "copyright_text": {
        "type": "Text",
        "config": {
          "label": "Copyright Text",
          "placeholder": ""
        }
      },
      "footer_description": {
        "type": "Text",
        "config": {
          "label": "Footer Description",
          "placeholder": ""
        }
      },
      "footer_newsletter_title": {
        "type": "Text",
        "config": {
          "label": "Footer Newsletter Title",
          "placeholder": ""
        }
      },
      "footer_newsletter_description": {
        "type": "StructuredText",
        "config": {
          "label": "Footer Newsletter Description",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,hyperlink"
        }
      }
    },
    "Social Profiles": {
      "social_profiles": {
        "type": "Link",
        "config": {
          "label": "Social Profiles",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": false,
          "allowText": false,
          "repeat": true,
          "variants": [
            "X (Twitter)",
            "Facebook",
            "LinkedIn",
            "Instagram",
            "TikTok",
            "YouTube"
          ]
        }
      }
    },
    "Default Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": ""
        }
      }
    },
    "Contact Details": {
      "contact_form_submission_email": {
        "type": "Text",
        "config": {
          "label": "Contact form submission email",
          "placeholder": ""
        }
      },
      "email": {
        "type": "Link",
        "config": {
          "label": "Email",
          "placeholder": "",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      }
    }
  }
}
